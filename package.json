{
  "name": "deal-manager",
  "private": true,
  "version": "1.0.0",
  "description": "Deal Manager",
  "author": "usaid",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.dealmanager.app",
    "files": ["dist/**/*", "electron.cjs"],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false
    },
    "publish": null
  }
}